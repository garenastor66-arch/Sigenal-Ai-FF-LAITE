{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user identity and the extracted AI memory.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "memory": { "type": "string", "description": "AI distilled memory of the user" },
        "lastMemoryUpdate": { "type": "number" }
      },
      "required": ["uid", "memory"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation thread.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "Message": {
      "title": "In-chat Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "chats/{chatId}": {
      "schema": "ChatSession",
      "description": "Main chat headers"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Conversation messages"
    }
  }
}
